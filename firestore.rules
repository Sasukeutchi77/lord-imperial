rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUsername(value) {
      return value is string
        && value.matches('^@[a-z0-9](?:[a-z0-9._]{1,22}[a-z0-9])?$');
    }

    function isNonEmptyString(value, maxSize) {
      return value is string && value.size() > 0 && value.size() <= maxSize;
    }

    function isOptionalString(value, maxSize) {
      return value == null || (value is string && value.size() <= maxSize);
    }

    function isOptionalInt(value) {
      return value == null || value is int;
    }

    function validActiveChatId(value, userId) {
      return value == null
        || (
          value is string
          && value.size() <= 128
          && conversationExists(value)
          && userId in conversationData(value).members
        );
    }

    function conversationExists(conversationId) {
      return exists(/databases/$(database)/documents/conversations/$(conversationId));
    }

    function conversationData(conversationId) {
      return get(/databases/$(database)/documents/conversations/$(conversationId)).data;
    }

    function isConversationMember(conversationId) {
      return isSignedIn()
        && conversationExists(conversationId)
        && request.auth.uid in conversationData(conversationId).members;
    }

    function isConversationAdmin(conversationId) {
      return isSignedIn()
        && conversationExists(conversationId)
        && request.auth.uid in conversationData(conversationId).admins;
    }

    function validConversationType(value) {
      return value in ['private', 'group', 'channel'];
    }

    function validConversationLastMessageType(value) {
      return value == null || value in ['text', 'audio', 'image', 'poll', 'system', 'deleted'];
    }

    function validPinnedMessage(data) {
      return data.pinnedMessage == null
        || (
          data.pinnedMessage is map
          && data.pinnedMessage.keys().hasOnly(['messageId', 'senderId', 'senderName', 'preview', 'type', 'pinnedBy', 'pinnedByName', 'pinnedAtMs'])
          && isOptionalString(data.pinnedMessage.messageId, 128)
          && isOptionalString(data.pinnedMessage.senderId, 128)
          && isOptionalString(data.pinnedMessage.senderName, 120)
          && isOptionalString(data.pinnedMessage.preview, 280)
          && isOptionalString(data.pinnedMessage.type, 20)
          && isOptionalString(data.pinnedMessage.pinnedBy, 128)
          && isOptionalString(data.pinnedMessage.pinnedByName, 120)
          && isOptionalInt(data.pinnedMessage.pinnedAtMs)
        );
    }

    function validPermissions(data) {
      return data.permissions is map
        && data.permissions.sendMessages in ['members', 'admins']
        && data.permissions.manageMembers == 'admins'
        && data.permissions.manageRoles == 'admins'
        && data.permissions.editInfo == 'admins';
    }

    function validConversationTitle(data) {
      return data.type == 'private'
        ? (data.title == null || isOptionalString(data.title, 80))
        : isNonEmptyString(data.title, 80);
    }

    function validConversationPayload(data, conversationId) {
      return data.keys().hasOnly([
          'id',
          'type',
          'title',
          'description',
          'members',
          'admins',
          'ownerId',
          'avatar',
          'createdBy',
          'memberRoles',
          'memberDetails',
          'permissions',
          'typingState',
          'invite',
          'pinnedMessage',
          'unreadCountByUser',
          'lastReadAt',
          'createdAt',
          'createdAtMs',
          'updatedAt',
          'updatedAtMs',
          'lastActivityAt',
          'lastActivityAtMs',
          'lastMessage',
          'lastMessageType',
          'lastMessageSenderId'
        ])
        && data.id == conversationId
        && validConversationType(data.type)
        && validConversationTitle(data)
        && isOptionalString(data.description, 240)
        && isOptionalString(data.avatar, 2000)
        && data.members is list
        && data.members.size() >= (data.type == 'private' ? 2 : 1)
        && data.members.size() <= 150
        && data.ownerId in data.members
        && data.admins is list
        && data.admins.size() >= 1
        && data.ownerId in data.admins
        && data.memberRoles is map
        && data.memberDetails is map
        && data.typingState is map
        && validPinnedMessage(data)
        && data.lastReadAt is map
        && data.unreadCountByUser is map
        && isOptionalString(data.lastMessage, 4000)
        && validConversationLastMessageType(data.lastMessageType)
        && isOptionalString(data.lastMessageSenderId, 128)
        && isOptionalInt(data.createdAtMs)
        && isOptionalInt(data.updatedAtMs)
        && isOptionalInt(data.lastActivityAtMs)
        && validPermissions(data);
    }

    function validConversationCreate(conversationId) {
      return validConversationPayload(request.resource.data, conversationId)
        && request.auth.uid == request.resource.data.ownerId
        && request.auth.uid in request.resource.data.members
        && request.auth.uid in request.resource.data.admins
        && request.resource.data.createdBy == request.auth.uid;
    }

    function validConversationUpdate(conversationId) {
      return validConversationPayload(request.resource.data, conversationId)
        && request.resource.data.id == resource.data.id
        && request.resource.data.type == resource.data.type;
    }

    function memberConversationUpdateKeys() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'typingState',
        'lastReadAt',
        'unreadCountByUser',
        'updatedAt',
        'updatedAtMs'
      ]);
    }

    function adminConversationUpdateKeys() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'title',
        'description',
        'avatar',
        'members',
        'admins',
        'ownerId',
        'memberRoles',
        'memberDetails',
        'permissions',
        'typingState',
        'invite',
        'pinnedMessage',
        'updatedAt',
        'updatedAtMs',
        'lastActivityAt',
        'lastActivityAtMs',
        'lastMessage',
        'lastMessageType',
        'lastMessageSenderId',
        'lastReadAt',
        'unreadCountByUser'
      ]);
    }

    function validMessageType(value) {
      return value in ['text', 'audio', 'image', 'poll', 'system'];
    }

    function validSenderSnapshot(data) {
      return data.senderSnapshot is map
        && data.senderSnapshot.uid == request.auth.uid
        && isOptionalString(data.senderSnapshot.username, 40)
        && isOptionalString(data.senderSnapshot.displayName, 60)
        && isOptionalString(data.senderSnapshot.email, 200)
        && isOptionalString(data.senderSnapshot.avatar, 2000);
    }

    function validDeliveryState(data) {
      return data.delivery is map
        && data.delivery.deliveredTo is list
        && data.delivery.seenBy is list;
    }

    function validReplyReference(data) {
      return data.replyTo == null
        || (
          data.replyTo is map
          && data.replyTo.keys().hasOnly(['messageId', 'senderId', 'senderName', 'type', 'preview'])
          && isOptionalString(data.replyTo.messageId, 128)
          && isOptionalString(data.replyTo.senderId, 128)
          && isOptionalString(data.replyTo.senderName, 120)
          && isOptionalString(data.replyTo.type, 20)
          && isOptionalString(data.replyTo.preview, 280)
        );
    }

    function validReactionsState(data) {
      return data.reactions == null || data.reactions is map;
    }

    function validPollState(data) {
      return data.poll == null
        || (
          data.poll is map
          && data.poll.keys().hasOnly(['question', 'options'])
          && isNonEmptyString(data.poll.question, 240)
          && data.poll.options is list
          && data.poll.options.size() >= 2
          && data.poll.options.size() <= 6
        );
    }

    function validMessagePayload(messageId) {
      return request.resource.data.keys().hasOnly([
          'clientId',
          'text',
          'audioUrl',
          'mediaUrl',
          'senderId',
          'senderSnapshot',
          'timestamp',
          'createdAtMs',
          'type',
          'durationMillis',
          'replyTo',
          'poll',
          'reactions',
          'deletedAt',
          'deletedBy',
          'delivery'
        ])
        && request.resource.data.clientId == messageId
        && request.resource.data.senderId == request.auth.uid
        && validMessageType(request.resource.data.type)
        && request.resource.data.createdAtMs is int
        && request.resource.data.createdAtMs > 0
        && request.resource.data.createdAtMs < request.time.toMillis() + 3600000
        && validSenderSnapshot(request.resource.data)
        && validDeliveryState(request.resource.data)
        && validReplyReference(request.resource.data)
        && validPollState(request.resource.data)
        && validReactionsState(request.resource.data)
        && (
          (
            request.resource.data.type == 'text'
            && isNonEmptyString(request.resource.data.text, 4000)
            && request.resource.data.audioUrl == null
            && request.resource.data.mediaUrl == null
          )
          || (
            request.resource.data.type == 'audio'
            && request.resource.data.text is string
            && request.resource.data.text.size() == 0
            && isOptionalString(request.resource.data.audioUrl, 2000)
            && isNonEmptyString(request.resource.data.mediaUrl, 2000)
          )
          || (
            request.resource.data.type == 'image'
            && request.resource.data.text is string
            && request.resource.data.text.size() == 0
            && request.resource.data.audioUrl == null
            && isNonEmptyString(request.resource.data.mediaUrl, 2000)
          )
          || (
            request.resource.data.type == 'poll'
            && isNonEmptyString(request.resource.data.text, 4000)
            && request.resource.data.audioUrl == null
            && request.resource.data.mediaUrl == null
            && validPollState(request.resource.data)
          )
          || (
            request.resource.data.type == 'system'
            && isNonEmptyString(request.resource.data.text, 4000)
          )
        );
    }

    function validDeletedMessageUpdate(conversationId) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'text',
          'audioUrl',
          'mediaUrl',
          'type',
          'durationMillis',
          'deletedAt',
          'deletedBy'
        ])
        && request.resource.data.type == 'deleted'
        && request.resource.data.text == 'Message supprimé'
        && request.resource.data.audioUrl == null
        && request.resource.data.mediaUrl == null
        && request.resource.data.deletedBy == request.auth.uid
        && (resource.data.senderId == request.auth.uid || isConversationAdmin(conversationId));
    }

    function validDeliveryOnlyUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['delivery'])
        && validDeliveryState(request.resource.data);
    }

    function validReactionOnlyUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['reactions'])
        && validReactionsState(request.resource.data);
    }

    function validPollOnlyUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['poll'])
        && validPollState(request.resource.data);
    }

    match /usernames/{usernameId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.keys().hasOnly(['uid', 'username', 'createdAt', 'updatedAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == ('@' + usernameId)
        && isValidUsername(request.resource.data.username)
        && (!resource.exists() || resource.data.uid == request.auth.uid);
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSelf(userId)
        && request.resource.data.uid == userId
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'username',
          'usernameLower',
          'displayName',
          'bio',
          'avatar',
          'avatarUpdatedAtMs',
          'activeChatId',
          'isOnline',
          'lastSeen',
          'updatedAt',
          'updatedAtMs',
          'createdAt',
          'notificationTokens',
          'notificationProvider',
          'notificationPlatform',
          'notificationsUpdatedAtMs'
        ])
        && isOptionalString(request.resource.data.email, 200)
        && (request.resource.data.username == null || isValidUsername(request.resource.data.username))
        && isOptionalString(request.resource.data.usernameLower, 40)
        && isNonEmptyString(request.resource.data.displayName, 60)
        && isOptionalString(request.resource.data.bio, 160)
        && isOptionalString(request.resource.data.avatar, 2000)
        && isOptionalInt(request.resource.data.avatarUpdatedAtMs)
        && validActiveChatId(request.resource.data.activeChatId, userId)
        && request.resource.data.isOnline is bool
        && (
          request.resource.data.notificationTokens == null
          || (
            request.resource.data.notificationTokens is list
            && request.resource.data.notificationTokens.size() <= 12
          )
        )
        && isOptionalString(request.resource.data.notificationProvider, 40)
        && isOptionalString(request.resource.data.notificationPlatform, 20)
        && isOptionalInt(request.resource.data.notificationsUpdatedAtMs)
        && isOptionalInt(request.resource.data.updatedAtMs);
      allow delete: if false;
    }

    match /conversations/{conversationId} {
      allow read: if isConversationMember(conversationId);

      allow create: if isSignedIn() && validConversationCreate(conversationId);

      allow update: if isConversationMember(conversationId)
        && validConversationUpdate(conversationId)
        && (
          (isConversationAdmin(conversationId) && adminConversationUpdateKeys())
          || memberConversationUpdateKeys()
        );

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isConversationMember(conversationId);

        allow create: if isConversationMember(conversationId)
          && validMessagePayload(messageId)
          && (
            conversationData(conversationId).permissions.sendMessages != 'admins'
            || isConversationAdmin(conversationId)
          );

        allow update: if isConversationMember(conversationId)
          && (
            validDeletedMessageUpdate(conversationId)
            || validDeliveryOnlyUpdate()
            || validReactionOnlyUpdate()
            || validPollOnlyUpdate()
          );

        allow delete: if false;
      }
    }
  }
}
