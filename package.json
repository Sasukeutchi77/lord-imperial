{
  "name": "lord-imperial",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "validate:js": "node ./scripts/validate-js.mjs",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-document-picker": "~13.0.4",
    "expo-file-system": "~19.0.17",
    "expo-font": "~14.0.11",
    "expo-haptics": "~14.0.1",
    "expo-image-manipulator": "~14.0.7",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.12",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "firebase": "^12.11.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "private": true,
  "devDependencies": {
    "@babel/parser": "^7.28.4",
    "@jest/globals": "^29.7.0",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "~54.0.10",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|firebase|@firebase)"
    ],
    "moduleNameMapper": {
      "^@react-native-async-storage/async-storage$": "<rootDir>/__mocks__/@react-native-async-storage/async-storage.js",
      "^expo-notifications$": "<rootDir>/__mocks__/expo-notifications.js",
      "^expo-haptics$": "<rootDir>/__mocks__/expo-haptics.js",
      "^react-native$": "<rootDir>/__mocks__/react-native.js",
      "^./firebase$": "<rootDir>/__mocks__/services/firebase.js",
      "^../services/firebase$": "<rootDir>/__mocks__/services/firebase.js",
      "^../../services/firebase$": "<rootDir>/__mocks__/services/firebase.js"
    },
    "collectCoverageFrom": [
      "utils/**/*.js",
      "services/offlineStore.js",
      "services/network.js",
      "services/logger.js",
      "!services/firebase.js",
      "!services/cloudinary.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 60,
        "lines": 60
      }
    }
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-av"
        ]
      }
    }
  }
}
